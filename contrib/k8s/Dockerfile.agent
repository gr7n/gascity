# syntax=docker/dockerfile:1.7
# Gas City agent container image — binary layer.
#
# Built on top of gc-agent-base (Dockerfile.base) which has all system
# dependencies. This layer only copies project binaries, so rebuilds
# after code changes take ~5s instead of ~2.5 min.
#
# Build:
#   make docker-agent
#   # or: docker build -f contrib/k8s/Dockerfile.agent -t gc-agent:latest .
#
# Full rebuild (base + agent):
#   make docker-base docker-agent
#
# gc and bd are built, and br is fetched, in source-bound BuildKit stages.
# Fleet therefore needs only the exact Gas City checkout plus the digest-pinned
# base artifact; no host-prepared binaries are part of the build contract.
ARG IMAGE_GO_BUILDER=docker.io/library/golang:1.26.5-bookworm@sha256:5ab8e9af080c5f58dab00dd8055ea9309ec54c47722681b5ee8d0a3602f85316
ARG BASE_IMAGE=gc-agent-base:latest
FROM ${IMAGE_GO_BUILDER} AS gascity-build
ARG GASCITY_COMMIT
WORKDIR /src
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl jq \
    && rm -rf /var/lib/apt/lists/*
COPY . .
RUN --mount=type=cache,id=gascity-go-mod,target=/go/pkg/mod,sharing=locked \
    --mount=type=cache,id=gascity-go-build,target=/root/.cache/go-build,sharing=locked \
    test "${#GASCITY_COMMIT}" -eq 40 \
    && case "$GASCITY_COMMIT" in *[!0-9a-f]*) exit 1 ;; esac \
    && .github/scripts/build-bd-image.sh /out/bd \
    && CGO_ENABLED=0 go build \
       -trimpath \
       -buildvcs=false \
       -ldflags "-X main.version=dev -X main.commit=${GASCITY_COMMIT} -X main.date=1970-01-01T00:00:00Z" \
       -o /out/gc ./cmd/gc \
    && ldd /out/gc 2>&1 | grep -q "not a dynamic executable"

# Validate br on the same libc/runtime base on which agents execute it.
FROM ${BASE_IMAGE} AS br-tool
USER root
WORKDIR /src
COPY deps.env .github/scripts/install-br-archive.sh ./
RUN --mount=type=cache,id=gascity-tool-downloads,target=/root/.cache/gr7n-downloads,sharing=locked \
    GR7N_TOOL_DOWNLOAD_CACHE=/root/.cache/gr7n-downloads \
    BR_INSTALL_BIN_DIR=/out ./install-br-archive.sh "$(sed -n 's/^BR_VERSION=//p' deps.env)"

FROM ${BASE_IMAGE}

# Build-time copies and ownership fixes require root; the final image drops
# back to gcagent below.
USER root

COPY --from=gascity-build /out/bd /usr/local/bin/bd
COPY --from=br-tool /out/br /usr/local/bin/br
COPY --from=gascity-build /out/gc /usr/local/bin/gc

# gc-beads-br script for the exec:beads protocol.
COPY contrib/beads-scripts/gc-beads-br /usr/local/bin/gc-beads-br

# gc-mail-mcp-agent-mail script for the exec:mail protocol.
COPY contrib/mail-scripts/gc-mail-mcp-agent-mail /usr/local/bin/gc-mail-mcp-agent-mail

# Claude credentials are injected at runtime via K8s Secret volume mount,
# not baked into the image. See contrib/k8s/README-credentials.md.
# The CLAUDE_CONFIG_DIR env var (set by gc-session-k8s) points to the mount.

WORKDIR /workspace
RUN chown gcagent:gcagent /workspace

# Default user. When LINUX_USERNAME is set, the pod spec overrides to root
# (UID 0) via securityContext so the entrypoint can create the dynamic user
# before dropping privileges.
USER gcagent

CMD ["/bin/bash"]
