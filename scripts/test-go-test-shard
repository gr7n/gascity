#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 3 ]]; then
  echo "usage: $0 <package> <shard-index> <shard-total>" >&2
  exit 1
fi

test_pkg="$1"
shard_index="$2"
shard_total="$3"

if ! [[ "$shard_index" =~ ^[0-9]+$ && "$shard_total" =~ ^[0-9]+$ ]]; then
  echo "shard index and total must be positive integers" >&2
  exit 1
fi
if (( shard_index < 1 || shard_total < 1 || shard_index > shard_total )); then
  echo "invalid shard ${shard_index} of ${shard_total}" >&2
  exit 1
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"
source "$repo_root/scripts/lib/common.sh"
# shellcheck source=lib/test-slice.sh
source "$repo_root/scripts/lib/test-slice.sh"
gc_test_slice_reexec "$repo_root/scripts/test-go-test-shard" "$@"

timeout="${GO_TEST_TIMEOUT:-20m}"

gopath_val="$(go env GOPATH)"
gocache_val="$(go env GOCACHE)"
gomodcache_val="$(go env GOMODCACHE)"
gotmpdir_val="$(go env GOTMPDIR)"
goroot_val="$(go env GOROOT)"

# Mirror the Makefile's CGO path detection here so tests run via this script
# see the same system dependency paths as `make`. When invoked from
# test-integration-shard, CGO_CPPFLAGS/CGO_LDFLAGS may already be set by that
# script; the helper avoids double-adding duplicate words.
cgo_cppflags="${CGO_CPPFLAGS:-}"
cgo_ldflags="${CGO_LDFLAGS:-}"
configure_cgo_platform_paths

extra_env=()
while IFS='=' read -r name _; do
  case "$name" in
    ANTHROPIC_*|CLAUDE_CODE_*|GC_ACCEPTANCE_KEEP|GC_TIERC_FORCE|GC_TUTORIAL_GOLDENS_USE_CLAUDE_FOR_CODEX)
      extra_env+=("${name}=${!name}")
      ;;
  esac
done < <(env)

run_in_test_env() {
  local base_env=(
    PATH="${PATH}" \
    HOME="${HOME:-}" \
    USER="${USER:-}" \
    LOGNAME="${LOGNAME:-}" \
    SHELL="${SHELL:-/bin/sh}" \
    LANG="${LANG:-C.UTF-8}" \
    TMPDIR="${TMPDIR:-/var/tmp}" \
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
    GOPATH="${gopath_val}" \
    GOCACHE="${gocache_val}" \
    GOMODCACHE="${gomodcache_val}" \
    GOTMPDIR="${gotmpdir_val}" \
    GOROOT="${GOROOT:-$goroot_val}" \
    GOMAXPROCS="${GOMAXPROCS:-}" \
    GOENV="${GOENV-}" \
    GOFLAGS="${GOFLAGS-}" \
    GO111MODULE="${GO111MODULE-}" \
    GOEXPERIMENT="${GOEXPERIMENT-}" \
    GOPROXY="${GOPROXY-}" \
    GOPRIVATE="${GOPRIVATE-}" \
    GONOPROXY="${GONOPROXY-}" \
    GONOSUMDB="${GONOSUMDB-}" \
    GOSUMDB="${GOSUMDB-}" \
    GOINSECURE="${GOINSECURE-}" \
    GOVCS="${GOVCS-}" \
    GOWORK="${GOWORK-}" \
    GC_FAST_UNIT="${GC_FAST_UNIT:-0}" \
    CGO_CPPFLAGS="${cgo_cppflags}" \
    CGO_LDFLAGS="${cgo_ldflags}" \
    GC_TEST_SHARD_INDEX="${shard_index}" \
    GC_TEST_SHARD_TOTAL="${shard_total}"
  )
  if (( ${#extra_env[@]} > 0 )); then
    env -i "${base_env[@]}" "${extra_env[@]}" "$@"
  else
    env -i "${base_env[@]}" "$@"
  fi
}

run_go_test() {
  run_in_test_env go test "$@"
}

run_observable_go_test() {
  local timing_name="${GO_TEST_TIMING_NAME:-${test_pkg#./}-shard-${shard_index}-of-${shard_total}}"
  local observable_env=(
    OBSERVABLE_TIMING_FILE="${GO_TEST_TIMING_FILE}"
    OBSERVABLE_SHARD_ID="${timing_name}"
    OBSERVABLE_VARIANT="${GO_TEST_TIMING_VARIANT:-default}"
    OBSERVABLE_COMMIT_SHA="${GITHUB_SHA:-}"
    OBSERVABLE_WORKFLOW="${GITHUB_WORKFLOW:-}"
    OBSERVABLE_RUN_ID="${GITHUB_RUN_ID:-}"
    OBSERVABLE_RUN_ATTEMPT="${GITHUB_RUN_ATTEMPT:-}"
    OBSERVABLE_JOB="${GITHUB_JOB:-}"
    OBSERVABLE_RUNNER_LABEL="${GO_TEST_RUNNER_LABEL:-}"
    OBSERVABLE_RUNNER_NAME="${RUNNER_NAME:-}"
    OBSERVABLE_RUNNER_OS="${RUNNER_OS:-}"
    OBSERVABLE_RUNNER_ARCH="${RUNNER_ARCH:-}"
    OBSERVABLE_RUNNER_CPU_COUNT="${GO_TEST_RUNNER_CPU_COUNT:-}"
  )
  if [[ "${GC_TEST_NO_SLICE:-0}" == "1" ]]; then
    observable_env+=(GC_TEST_NO_SLICE=1)
  fi
  run_in_test_env "${observable_env[@]}" \
    "$repo_root/scripts/go-test-observable" "$timing_name" -- "$@"
}

sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
    return
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
    return
  fi
  echo "no SHA-256 tool is available" >&2
  return 1
}

prepared_binary="${GO_TEST_PREPARED_BINARY:-}"
prepared_package_dir="${GO_TEST_PREPARED_PACKAGE_DIR:-}"
prepared_binary_sha256="${GO_TEST_PREPARED_BINARY_SHA256:-}"
prepared_manifest_sha256="${GO_TEST_MANIFEST_SHA256:-}"
prepare_binary="${GO_TEST_PREPARE_BINARY:-}"
prepare_manifest="${GO_TEST_PREPARE_MANIFEST:-}"

if [[ -n "$prepare_binary" || -n "$prepare_manifest" ]]; then
  if [[ -z "$prepare_binary" || -z "$prepare_manifest" ]]; then
    echo "GO_TEST_PREPARE_BINARY and GO_TEST_PREPARE_MANIFEST must be supplied together" >&2
    exit 1
  fi
  if [[ -n "$prepared_binary" || ${GO_TEST_MANIFEST+x} == x ]]; then
    echo "prepared test outputs cannot be combined with prepared test inputs" >&2
    exit 1
  fi
fi

if [[ -n "$prepared_binary" ]]; then
  if [[ ${GO_TEST_MANIFEST+x} != x || -z "$prepared_package_dir" ||
    -z "$prepared_binary_sha256" || -z "$prepared_manifest_sha256" ]]; then
    echo "prepared test mode requires binary, manifest, package directory, and both SHA-256 digests" >&2
    exit 1
  fi
  if [[ "$test_pkg" != "./cmd/gc" || -n "${GO_TEST_TAGS:-}" ||
    -n "${GO_TEST_COVERPROFILE:-}" || -n "${GO_TEST_TIMING_FILE:-}" ]]; then
    echo "prepared test mode supports only untagged, non-coverage, non-observable ./cmd/gc shards" >&2
    exit 1
  fi
  if [[ "$prepared_binary" != /* || "$prepared_binary" != *.test ||
    ! -f "$prepared_binary" || ! -x "$prepared_binary" || -L "$prepared_binary" ]]; then
    echo "prepared test binary must be an absolute, executable, non-symlinked .test file" >&2
    exit 1
  fi
  if [[ ! -f "$GO_TEST_MANIFEST" || ! -r "$GO_TEST_MANIFEST" || -L "$GO_TEST_MANIFEST" ]]; then
    echo "prepared test manifest must be a readable, non-symlinked file" >&2
    exit 1
  fi
  if [[ "$prepared_package_dir" != /* || ! -d "$prepared_package_dir" ||
    "$(cd "$prepared_package_dir" && pwd -P)" != "$repo_root/cmd/gc" ]]; then
    echo "prepared test package directory must resolve to the repository cmd/gc directory" >&2
    exit 1
  fi
  if ! [[ "$prepared_binary_sha256" =~ ^[a-f0-9]{64}$ &&
    "$prepared_manifest_sha256" =~ ^[a-f0-9]{64}$ ]]; then
    echo "prepared test digests must be lowercase SHA-256 values" >&2
    exit 1
  fi
  if [[ "$(sha256_file "$prepared_binary")" != "$prepared_binary_sha256" ]]; then
    echo "prepared test binary digest mismatch" >&2
    exit 1
  fi
  if [[ "$(sha256_file "$GO_TEST_MANIFEST")" != "$prepared_manifest_sha256" ]]; then
    echo "prepared test manifest digest mismatch" >&2
    exit 1
  fi
fi

go_test_args=(-timeout "$timeout")
if [[ -n "${GO_TEST_TAGS:-}" ]]; then
  go_test_args=(-tags "$GO_TEST_TAGS" "${go_test_args[@]}")
fi
if [[ -n "${GO_TEST_COUNT:-}" ]]; then
  go_test_args=(-count="$GO_TEST_COUNT" "${go_test_args[@]}")
fi
if [[ -n "${GO_TEST_COVERPROFILE:-}" ]]; then
  go_test_args+=(-coverpkg=./... -coverprofile "$GO_TEST_COVERPROFILE")
fi

tests=()
if [[ -n "$prepare_binary" ]]; then
  if [[ "$test_pkg" != "./cmd/gc" || -n "${GO_TEST_TAGS:-}" ||
    -n "${GO_TEST_COVERPROFILE:-}" || -n "${GO_TEST_TIMING_FILE:-}" ]]; then
    echo "prepared test creation supports only untagged, non-coverage, non-observable ./cmd/gc" >&2
    exit 1
  fi
  if [[ "$prepare_binary" != /* || "$prepare_binary" != *.test ||
    "$prepare_manifest" != /* || -e "$prepare_binary" || -L "$prepare_binary" ||
    -e "$prepare_manifest" || -L "$prepare_manifest" ||
    ! -d "$(dirname "$prepare_binary")" || ! -d "$(dirname "$prepare_manifest")" ]]; then
    echo "prepared test outputs must be new absolute paths in existing directories and the binary must end in .test" >&2
    exit 1
  fi

  package_dir="$(run_in_test_env go list -f '{{.Dir}}' "$test_pkg")"
  if [[ "$package_dir" != /* || ! -d "$package_dir" ||
    "$(cd "$package_dir" && pwd -P)" != "$repo_root/cmd/gc" ]]; then
    echo "go list returned an unexpected cmd/gc package directory" >&2
    exit 1
  fi

  temporary_binary="$(mktemp "${prepare_binary}.tmp.XXXXXX")"
  temporary_manifest="$(mktemp "${prepare_manifest}.tmp.XXXXXX")"
  cleanup_prepared_outputs() {
    rm -f "$temporary_binary" "$temporary_manifest"
  }
  trap cleanup_prepared_outputs EXIT
  if ! run_go_test -c -o "$temporary_binary" "$test_pkg"; then
    echo "prepared test binary compilation failed for ${test_pkg}" >&2
    exit 1
  fi
  chmod 0555 "$temporary_binary"
  if ! list_output="$(run_in_test_env bash -c \
    'set -e; cd "$1"; shift; exec "$@"' _ "$package_dir" "$temporary_binary" -test.paniconexit0 -test.list '^Test' 2>&1)"; then
    echo "prepared test binary listing failed for ${test_pkg}; output:" >&2
    printf '%s\n' "$list_output" >&2
    exit 1
  fi
  prepared_test_count=0
  while IFS= read -r line; do
    [[ "$line" == Test* ]] || continue
    if ! [[ "$line" =~ ^Test$ || "$line" =~ ^Test[A-Z0-9_][A-Za-z0-9_]*$ ]]; then
      echo "prepared test binary returned an invalid test name: ${line}" >&2
      exit 1
    fi
    printf '%s\n' "$line"
    prepared_test_count=$((prepared_test_count + 1))
  done <<< "$list_output" > "$temporary_manifest"
  if (( prepared_test_count == 0 )); then
    echo "prepared test binary returned no tests for ${test_pkg}" >&2
    exit 1
  fi
  duplicate_prepared_tests="$(LC_ALL=C sort "$temporary_manifest" | uniq -d)"
  if [[ -n "$duplicate_prepared_tests" ]]; then
    echo "prepared test binary returned a duplicate test: ${duplicate_prepared_tests%%$'\n'*}" >&2
    exit 1
  fi
  chmod 0444 "$temporary_manifest"
  mv "$temporary_binary" "$prepare_binary"
  mv "$temporary_manifest" "$prepare_manifest"
  trap - EXIT
  printf 'Prepared %s with %d tests\n' "$prepare_binary" "$prepared_test_count"
  exit 0
elif [[ ${GO_TEST_MANIFEST+x} == x ]]; then
  if [[ ! -f "$GO_TEST_MANIFEST" || ! -r "$GO_TEST_MANIFEST" ]]; then
    echo "go test manifest is not readable: ${GO_TEST_MANIFEST}" >&2
    exit 1
  fi
  if ! LC_ALL=C tr -d '\000' < "$GO_TEST_MANIFEST" | cmp -s "$GO_TEST_MANIFEST" -; then
    echo "go test manifest contains NUL bytes or could not be validated: ${GO_TEST_MANIFEST}" >&2
    exit 1
  fi

  line_number=0
  manifest_test_count=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line_number=$((line_number + 1))
    if [[ "$line" =~ ^[[:space:]]*$ || "$line" =~ ^[[:space:]]*# ]]; then
      continue
    fi
    if ! [[ "$line" =~ ^Test$ || "$line" =~ ^Test[A-Z0-9_][A-Za-z0-9_]*$ ]]; then
      echo "invalid go test manifest entry in ${GO_TEST_MANIFEST} at line ${line_number}: ${line}" >&2
      exit 1
    fi
    tests+=("$line")
    manifest_test_count=$((manifest_test_count + 1))
  done < "$GO_TEST_MANIFEST"

  if (( manifest_test_count == 0 )); then
    echo "go test manifest contains no tests: ${GO_TEST_MANIFEST}" >&2
    exit 1
  fi
  duplicate_manifest_tests="$(printf '%s\n' "${tests[@]}" | LC_ALL=C sort | uniq -d)"
  if [[ -n "$duplicate_manifest_tests" ]]; then
    echo "duplicate go test manifest entry: ${duplicate_manifest_tests%%$'\n'*}" >&2
    exit 1
  fi
else
  # Capture the enumeration separately so a build/compile failure here surfaces
  # its output. `go test -list` builds the test binary; if that fails, the bare
  # assignment's non-zero status is swallowed by `set -e` (the script dies before
  # the "no tests discovered" branch below), producing an undebuggable empty
  # shard failure. Check the status explicitly and print what go printed.
  if ! list_output="$(run_go_test "${go_test_args[@]}" "$test_pkg" -list '^Test' 2>&1)"; then
    echo "go test -list failed for ${test_pkg} (build/compile error); output:" >&2
    printf '%s\n' "$list_output" >&2
    exit 1
  fi
  while IFS= read -r line; do
    [[ "$line" == Test* ]] || continue
    tests+=("$line")
  done <<< "$list_output"

  if [[ ${#tests[@]} -eq 0 ]]; then
    echo "no tests discovered for ${test_pkg}; go test -list output:" >&2
    printf '%s\n' "$list_output" >&2
    exit 1
  fi
fi

selected=()
for i in "${!tests[@]}"; do
  if (( i % shard_total == shard_index - 1 )); then
    selected+=("${tests[$i]}")
  fi
done

if [[ ${#selected[@]} -eq 0 ]]; then
  echo "no tests selected for ${test_pkg} shard ${shard_index} of ${shard_total}" >&2
  exit 1
fi

join_regex() {
  local IFS='|'
  printf '%s' "$*"
}

regex="^($(join_regex "${selected[@]}"))$"
echo "Running ${test_pkg} shard ${shard_index} of ${shard_total} (${#selected[@]} tests)"
printf '  %s\n' "${selected[@]}"
if [[ -n "$prepared_binary" ]]; then
  prepared_args=(-test.paniconexit0 -test.timeout "$timeout")
  if [[ -n "${GO_TEST_COUNT:-}" ]]; then
    prepared_args+=("-test.count=${GO_TEST_COUNT}")
  fi
  prepared_args+=(-test.run "$regex")
  run_in_test_env bash -c \
    'set -e; cd "$1"; shift; exec "$@"' _ "$prepared_package_dir" "$prepared_binary" "${prepared_args[@]}"
elif [[ -n "${GO_TEST_TIMING_FILE:-}" ]]; then
  run_observable_go_test "${go_test_args[@]}" "$test_pkg" -run "$regex"
else
  run_go_test "${go_test_args[@]}" "$test_pkg" -run "$regex"
fi
